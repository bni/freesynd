{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 22,
    "patch": 0
  },

  "configurePresets": [
    {
      "name": "sdl-default",
      "hidden": true,
      "description": "Default Config for SDL and SDL Mixer",
      "cacheVariables": {
        "USE_SYSTEM_SDL": "ON",
        "USE_SDL_MIXER": "ON"
      }
    },
    {
      "name": "codeblocks-unixmakefile",
      "hidden": true,
      "description": "Generator for CodeBlocks with makefile",
      "generator": "CodeBlocks - Unix Makefiles"
    },
    {
      "name": "unixmakefile",
      "hidden": true,
      "description": "Generator for Unix makefile",
      "generator": "Unix Makefiles"
    },
    {
      "name": "debug",
      "hidden": true,
      "description": "Single configuration Debug",
      "environment": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "hidden": true,
      "description": "Single configuration Release",
      "environment": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "gcc-flags",
      "hidden": true,
      "description": "Compiler flags for GCC",
      "cacheVariables": {
        "EXTRA_CXX_FLAGS": "-Wall -Wshadow -Wno-multichar -Wreorder -Wnon-virtual-dtor"
      }
    },
    {
      "name": "cb_makefile-x86_64-linux-debug",
      "displayName": "Code::Blocks with Makefile with Debug configuration",
      "description": "Code::Blocks with Makefile with Debug configuration",
      "hidden": false,
      "inherits": ["debug", "gcc-flags", "sdl-default", "codeblocks-unixmakefile"],
      "binaryDir": "build-cb-debug"
    },
    {
      "name": "cb_makefile-x86_64-linux-release",
      "displayName": "Code::Blocks with Makefile with Release configuration",
      "description": "Code::Blocks with Makefile with Release configuration",
      "hidden": false,
      "inherits": ["release", "gcc-flags", "sdl-default", "codeblocks-unixmakefile"],
      "binaryDir": "build-cb-release"
    },
    {
      "name": "makefile-x86_64-linux-debug",
      "displayName": "Linux Makefile with Debug configuration",
      "description": "Linux Makefile with Debug configuration",
      "hidden": false,
      "inherits": ["debug", "gcc-flags", "sdl-default", "unixmakefile"],
      "binaryDir": "build-mkf-debug"
    },
    {
      "name": "makefile-x86_64-linux-release",
      "displayName": "Linux Makefile with Release configuration",
      "description": "Single configuration Release",
      "hidden": false,
      "inherits": ["release", "gcc-flags", "sdl-default", "unixmakefile"],
      "binaryDir": "build-mkf-release"
    }
  ]
}
